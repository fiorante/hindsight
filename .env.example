# Environment Configuration Template for Hindsight Platform
# Copy this file to .env and update the values as needed

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=drive_analysis
DB_USER=hindsight
DB_PASSWORD=hindsight_dev_password

# Alternative: Use full DATABASE_URL instead of component variables
# DATABASE_URL=postgresql://hindsight:hindsight_dev_password@localhost:5432/drive_analysis

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
DEBUG=true

# =============================================================================
# DATA PATHS (relative to repository root)
# =============================================================================
DATA_INTERP_PATH=data/pds/best_interp.csv
DATA_OBSERVATIONS_PATH=data/pds/best_tactical.csv
DATA_EVR_PATH=data/unlimited_release_m20_data/EVRs
DATA_MOBILITY_PATH=data/unlimited_release_m20_data/telemetry_sys_mob_1040_1055/SOLS_1040_1055_SYS_MOB.csv
DATA_MOTOR_PATH=data/unlimited_release_m20_data/telemetry_drive_steer_1040_1055

# Sol range for data processing
MIN_SOL=1040
MAX_SOL=1055

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# These are used when running in Docker containers

# Docker database configuration (when using docker-compose)
DOCKER_DB_HOST=database
DOCKER_DB_PORT=5432

# Frontend configuration
VITE_API_BASE_URL=http://localhost:8000

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Enable uvicorn reload in development
UVICORN_RELOAD=true

# Node environment
NODE_ENV=development
